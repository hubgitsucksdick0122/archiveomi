# Google Cloud Storage bucket name (required)
GCS_BUCKET_NAME=archiveomi-files

# Path to service account JSON key file (default: ./service-account.json)
# GCS_KEY_FILE=./service-account.json

# OR embed the full service account JSON as a single-line string
# GCS_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# HTTP port (default: 3000)
PORT=3000
